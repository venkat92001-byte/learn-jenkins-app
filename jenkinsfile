pipeline {
    agent any

    stages {
        stage('Build') {
            agent{
                docker {
                    image 'node:alpine'
                    reuseNode true
                }
            }
            steps {
                sh '''
                ls -la
                node --version
                npm --version
                npm ci
                npm run build
                ls -la
                '''
             }
        }
        stage('TEST'){
            agent{
                docker {
                    image 'node:alpine'
                    reuseNode true
                }
            }
            steps {
                sh 'echo "test stage"'
                sh 'test -f /build/index.html'
                sh 'npm test'
            
            }
            
        }
    }
}