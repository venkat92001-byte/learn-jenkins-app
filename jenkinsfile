pipeline {
    agent any

    stages {
        stage('Build') {
            agent{
                docker {
                    image 'node:alpine'
                    reuseNode true
                }
            }
            steps {
                sh '''
                ls -la
                node --version
                npm --version
                npm ci
                npm run build
                ls -la
                '''
             }
        }
        stage('TEST'){
            agent{
                docker {
                    image 'node:alpine'
                    reuseNode true
                }
            }
            steps {
                sh 'echo "test stage"'
                sh 'test -f build/index.html'
                sh 'npm test'
            
            }
            
        }
        stage('E2E'){
            agent{
                docker {
                    image 'mcr.microsoft.com/playwright:v1.58.2-noble'
                    reuseNode true
                }
            }
            steps {
                sh '''
                   npm install serve
                   node_modules/.bin/serve -s build & 
                   sleep 10
                   npx playwright test
                '''
                
            
            }
            
        }
    }
    post {
        always{
            junit 'jest-results/junit.xml'
        }
    }
}