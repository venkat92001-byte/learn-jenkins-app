pipeline {
    agent any
    environment {
        NETLIFY_SITE_ID = 'c8fa8e9c-2dcf-4564-aa35-738e89cc1c5b'
        NETLIFY_AUTH_TOKEN = credentials('netlify-token')
        
    }

    stages {
        stage('Build') {
            agent{
                docker {
                    image 'node:24.13.1'
                    reuseNode true
                }
            }
            steps {
                sh '''
                ls -la
                node --version
                npm --version
                npm ci
                npm run build
                ls -la
              '''
            }
        }
        stage('run tests') {
            parallel{
                stage('TEST') {
                    agent{
                        docker {
                            image 'node:24.13.1'
                            reuseNode true
                        }
                    }
                    steps {
                        sh 'echo "test stage"'
                        sh 'test -f build/index.html'
                        sh 'npm test'
                    }
                }
                stage('E2E') {
                    agent{
                        docker {
                            image 'mcr.microsoft.com/playwright:v1.39.0'
                            reuseNode true
                        }
                    }
                    steps {
                        sh '''
                        npm install serve
                        node_modules/.bin/serve -s build & 
                        sleep 10
                        npx playwright test --reporter=html
                         '''
                    }
                    post {
                        always {
                            junit 'jest-results/junit.xml'
                            publishHTML([allowMissing: false, alwaysLinkToLastBuild: false, icon: '', keepAll: false, reportDir: 'playwright-report', reportFiles: 'index.html', reportName: 'playwrightlocal', reportTitles: '', useWrapperFileDirectly: true])
                        }
                    }
                }
            } 
        }
        stage('deploy stage') {
            agent {
                docker {
                    image 'node:24.13.1'
                    reuseNode true
                }
            }
            steps {
                sh 'npm i netlify-cli@24.0.1'
                sh 'node_modules/.bin/netlify --version'
                sh  'echo "deploying to staging. Site ID: $NETLIFY_SITE_ID"'
                sh 'node_modules/.bin/netlify status'
                sh 'node_modules/.bin/netlify deploy --dir=build'
            }
        }
        stage('deploy prod') {
            agent {
                docker {
                    image 'node:24.13.1'
                    reuseNode true
                }
            }
            steps {
                sh 'npm i netlify-cli@24.0.1'
                sh 'node_modules/.bin/netlify --version'
                sh  'echo "deploying to production. Site ID: $NETLIFY_SITE_ID"'
                sh 'node_modules/.bin/netlify status'
                sh 'node_modules/.bin/netlify deploy --dir=build --prod'
            }
        }
        stage('prod E2E') {
            agent{
                docker {
                    image 'mcr.microsoft.com/playwright:v1.39.0'
                    reuseNode true
                }
            }
            environment{
                CI_ENVIRONMENT_URL = 'https://soft-malasada-3af2fa.netlify.app'
            }
            steps {
                sh '''
                    npx playwright test --reporter=html
                    '''
            }
        
            post {
                always {
                    junit 'jest-results/junit.xml'
                    publishHTML([allowMissing: false, alwaysLinkToLastBuild: false, icon: '', keepAll: false, reportDir: 'playwright-report', reportFiles: 'index.html', reportName: 'playwrightE2E Report', reportTitles: '', useWrapperFileDirectly: true])
                }
            }
        }
    }
}